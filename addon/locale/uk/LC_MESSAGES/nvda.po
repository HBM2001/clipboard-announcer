#: addon\globalPlugins\clipboardAnnouncer.py:49
msgid "Always announce"
msgstr "Завжди оголошувати"

#: addon\globalPlugins\clipboardAnnouncer.py:50
msgid "Smart (avoid repeated announcements)"
msgstr "Розумний (уникати повторних оголошень)"

#. Translators: Summary/title for this add-on shown in install dialogs and the add-on store.
#: addon\globalPlugins\clipboardAnnouncer.py:142
#: addon\globalPlugins\clipboardAnnouncer.py:281
#: addon\globalPlugins\clipboardAnnouncer.py:1279 buildVars.py:17
msgid "Clipboard Announcer"
msgstr "Оголошення буфера обміну"

#: addon\globalPlugins\clipboardAnnouncer.py:143
msgid "Configure announcements and clipboard clearing behavior."
msgstr "Налаштування сповіщень та очищення буфера обміну."

#: addon\globalPlugins\clipboardAnnouncer.py:150
msgid "Enable spoken shortcut feedback"
msgstr "Увімкнути голосові підказки комбінацій клавіш"

#: addon\globalPlugins\clipboardAnnouncer.py:156
msgid "Announcement behavior:"
msgstr "Поведінка оголошень:"

#: addon\globalPlugins\clipboardAnnouncer.py:164
msgid "Shortcuts to announce"
msgstr "Оголошення для комбінацій"

#: addon\globalPlugins\clipboardAnnouncer.py:165
msgid "Announce Copy"
msgstr "Оголошувати Копіювати"

#: addon\globalPlugins\clipboardAnnouncer.py:166
msgid "Announce Cut"
msgstr "Оголошувати Вирізати"

#: addon\globalPlugins\clipboardAnnouncer.py:167
msgid "Announce Paste"
msgstr "Оголошувати Вставити"

#: addon\globalPlugins\clipboardAnnouncer.py:168
msgid "Announce Select All"
msgstr "Оголошувати Вибрати все"

#: addon\globalPlugins\clipboardAnnouncer.py:169
msgid "Announce Undo"
msgstr "Оголошувати Скасувати"

#: addon\globalPlugins\clipboardAnnouncer.py:170
msgid "Announce Redo"
msgstr "Оголошувати Повторити"

#: addon\globalPlugins\clipboardAnnouncer.py:171
msgid "Announce Append Copy"
msgstr "Оголошувати додати копію"

#: addon\globalPlugins\clipboardAnnouncer.py:172
msgid "Announce Copy Path"
msgstr "Оголошувати Копіювати шлях"

#: addon\globalPlugins\clipboardAnnouncer.py:174
msgid "Use smart clipboard feedback for Copy, Cut, and Paste"
msgstr ""
"Використовувати інтелектуальні функції буфера обміну для команд «Копіювати», "
"«Вирізати» та «Вставити»"

#: addon\globalPlugins\clipboardAnnouncer.py:203
msgid "Speak the result after clearing the clipboard"
msgstr "Оголошувати результат після очищення буфера обміну"

#: addon\globalPlugins\clipboardAnnouncer.py:208
msgid "Ask before clearing the clipboard"
msgstr "Запитувати перед очищенням буфера обміну"

#: addon\globalPlugins\clipboardAnnouncer.py:213
msgid "Clipboard warnings and status messages"
msgstr "Попередження та повідомлення про стан буфера обміну"

#: addon\globalPlugins\clipboardAnnouncer.py:216
msgid "Speak an error if the clipboard cannot be accessed"
msgstr ""
"Оголошувати повідомлення про помилку, якщо немає доступу до буфера обміну"

