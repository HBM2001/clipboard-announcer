msgid "Always announce"
msgstr "Luôn thông báo"

msgid "Smart (avoid repeated announcements)"
msgstr "Thông minh (tránh lặp lại thông báo)"

msgid "Clipboard Announcer"
msgstr "Trình thông báo bảng tạm"

msgid "Configure announcements and clipboard clearing behavior."
msgstr "Thiết lập cách thông báo và cách xóa bảng tạm."

msgid "Speak when these shortcuts are pressed"
msgstr "Đọc thông báo khi nhấn các phím tắt sau"

msgid "Announcement behavior:"
msgstr "Cách đọc thông báo:"

msgid "Shortcuts to announce"
msgstr "Phím tắt cần thông báo"

msgid "Announce Copy"
msgstr "Thông báo khi sao chép"

msgid "Announce Cut"
msgstr "Thông báo khi cắt"

msgid "Announce Paste"
msgstr "Thông báo khi dán"

msgid "Announce Select All"
msgstr "Thông báo khi chọn tất cả"

msgid "Announce Undo"
msgstr "Thông báo khi hoàn tác"

msgid "Announce Redo"
msgstr "Thông báo khi làm lại"

msgid "Announce Copy Path"
msgstr "Thông báo khi sao chép đường dẫn"

msgid "Use clipboard content awareness for Copy and Paste"
msgstr "Nhận diện nội dung bảng tạm cho Sao chép và Dán"

msgid "Speak the result after clearing the clipboard"
msgstr "Đọc kết quả sau khi xóa bảng tạm"

msgid "Ask before clearing the clipboard"
msgstr "Hỏi trước khi xóa bảng tạm"

msgid "Clipboard warnings and status messages"
msgstr "Cảnh báo và thông báo về bảng tạm"

msgid "Warn if you try to paste when the clipboard is empty"
msgstr "Cảnh báo khi bạn dán mà bảng tạm đang trống"

msgid "Speak an error if the clipboard cannot be accessed"
msgstr "Đọc lỗi nếu không thể truy cập bảng tạm"

msgid "Copy"
msgstr "Sao chép"

msgid "Nothing to copy"
msgstr "Không có gì để sao chép"

msgid "Nothing to cut"
msgstr "Không có gì để cắt"

msgid "Could not access clipboard"
msgstr "Không thể truy cập bảng tạm"

msgid "Nothing to paste"
msgstr "Không có gì để dán"

msgid "Paste"
msgstr "Dán"

msgid "Could not open the clipboard."
msgstr "Không thể mở bảng tạm."

msgid "Could not copy text to the clipboard."
msgstr "Không thể chép văn bản vào bảng tạm."

msgid "Clipboard is already empty."
msgstr "Bảng tạm đã trống."

msgid "Could not empty the clipboard."
msgstr "Không thể làm trống bảng tạm."

msgid "Clipboard is already empty"
msgstr "Bảng tạm đã trống"

msgid "Could not clear clipboard"
msgstr "Không thể xóa bảng tạm"

msgid "Clipboard cleared"
msgstr "Đã xóa bảng tạm"

msgid "Are you sure you want to clear the clipboard?"
msgstr "Bạn có chắc muốn xóa bảng tạm không?"

msgid "Open the Clipboard Announcer settings panel."
msgstr "Mở bảng cài đặt của Trình thông báo bảng tạm."

msgid "Temporarily disable or enable Clipboard Announcer."
msgstr "Tạm thời tắt hoặc bật Trình thông báo bảng tạm."

msgid "Clipboard Announcer temporarily disabled"
msgstr "Trình thông báo bảng tạm đã tạm thời bị tắt"

msgid "Clipboard Announcer enabled"
msgstr "Trình thông báo bảng tạm đã được bật"

msgid "Copy the selected file or folder path."
msgstr "Sao chép đường dẫn của tệp hoặc thư mục đang chọn."

msgid "Path copied"
msgstr "Đã sao chép đường dẫn"

msgid "Copied %d paths"
msgstr "Đã sao chép %d đường dẫn"

msgid "Announce Copy."
msgstr "Thông báo khi sao chép."

msgid "Announce Cut."
msgstr "Thông báo khi cắt."

msgid "Cut"
msgstr "Cắt"

msgid "Announce Paste."
msgstr "Thông báo khi dán."

msgid "Announce Select All."
msgstr "Thông báo khi chọn tất cả."

msgid "Select all"
msgstr "Chọn tất cả"

msgid "Announce Undo."
msgstr "Thông báo khi hoàn tác."

msgid "Undo"
msgstr "Hoàn tác"

msgid "Announce Redo."
msgstr "Thông báo khi làm lại."

msgid "Redo"
msgstr "Làm lại"

msgid "Clear Clipboard."
msgstr "Xóa bảng tạm."

msgid "Provides spoken feedback for common editing and clipboard actions."
msgstr "Cung cấp phản hồi bằng giọng nói cho các thao tác chỉnh sửa và bảng tạm thường dùng."

msgid "Added clipboard content awareness for Copy and Paste, improved Copy and Cut feedback when nothing is selected, added smarter announcements for multiple file selections, and introduced a shortcut to temporarily silence the add-on."
msgstr "Đã thêm khả năng nhận diện nội dung bảng tạm cho Sao chép và Dán, cải thiện phản hồi của Sao chép và Cắt khi không có văn bản hoặc tệp nào được chọn, bổ sung thông báo thông minh hơn khi chọn nhiều tệp, và thêm phím tắt để tạm thời tắt tiếng add-on."

msgid "Copy text"
msgstr "Sao chép văn bản"

msgid "Copy file"
msgstr "Sao chép tệp"

msgid "Copy files"
msgstr "Sao chép nhiều tệp"

msgid "Copy %d files"
msgstr "Sao chép %d tệp"

msgid "Copy image"
msgstr "Sao chép hình ảnh"

msgid "Copy clipboard content"
msgstr "Sao chép nội dung bảng tạm"

msgid "Cut text"
msgstr "Cắt văn bản"

msgid "Cut file"
msgstr "Cắt tệp"

msgid "Cut files"
msgstr "Cắt nhiều tệp"

msgid "Cut %d files"
msgstr "Cắt %d tệp"

msgid "Cut image"
msgstr "Cắt hình ảnh"

msgid "Cut clipboard content"
msgstr "Cắt nội dung bảng tạm"

msgid "Paste text"
msgstr "Dán văn bản"

msgid "Paste files"
msgstr "Dán tệp"

msgid "Paste image"
msgstr "Dán hình ảnh"

msgid "Paste clipboard content"
msgstr "Dán nội dung bảng tạm"
